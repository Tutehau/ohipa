# --- Serveur ---
PORT=3000
# URL publique de base (liens dans les emails)
BASE_URL=http://localhost:3000
# Environnement : development | production | test
NODE_ENV=production
# Cookie de session en HTTPS uniquement. Mettre à true UNIQUEMENT derrière un
# proxy TLS / HTTPS, sinon le navigateur ne renvoie pas le cookie (login cassé).
COOKIE_SECURE=false

# --- Sécurité (obligatoires) ---
# Secret de signature des sessions. Générer une valeur longue et aléatoire :
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=
# Clé requise pour créer le tout premier compte administrateur
SETUP_KEY=change-me-setup-key

# --- Email SMTP (activation, invitation, reset de mot de passe) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Ohipa <no-reply@ohipa.app>"

# --- Base de données (optionnel) ---
# Chemin du fichier SQLite (défaut : data/worktime.db)
# DB_PATH=data/worktime.db
